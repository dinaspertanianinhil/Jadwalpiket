<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jadwal Piket Jumat</title>

<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

<style>
/* (STYLE SAMA PERSIS — GAK DIUBAH) */
body{
    margin:0;
    font-family:'Poppins','Segoe UI',sans-serif;
    background:url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTdDTXGJIkjphkmC30hMYVpmbZwDdy1XzTH3jFDe16W10jQRXa5mLkwfmLq&s=10') no-repeat center center fixed;
    background-size:cover;
    color:white;
}
.overlay{
    background:linear-gradient(135deg, rgba(0,0,0,0.75), rgba(0,40,0,0.75));
    min-height:100vh;
    padding:60px 20px;
    display:flex;
    flex-direction:column;
    align-items:center;
}
.header-dinas{text-align:center;margin-bottom:40px;}
.header-dinas h1{margin:0;font-size:26px;letter-spacing:3px;font-weight:700;}
.header-dinas p{margin-top:8px;font-size:14px;letter-spacing:2px;opacity:0.9;}
.card{
    width:100%;
    max-width:520px;
    padding:35px;
    border-radius:25px;
    backdrop-filter:blur(18px);
    background:rgba(255,255,255,0.12);
    border:1px solid rgba(255,255,255,0.25);
    box-shadow:0 25px 60px rgba(0,0,0,0.6);
    text-align:center;
}
.card h3{margin:0 0 15px 0;font-size:18px;letter-spacing:2px;font-weight:600;}
.tanggal{margin-bottom:20px;font-size:14px;opacity:0.9;}
ul{list-style:none;padding:0;margin:0 0 25px 0;}
li{
    padding:12px;margin:8px 0;border-radius:14px;
    background:rgba(255,255,255,0.15);
}
.floating-download{
    position:fixed;right:20px;bottom:20px;
    width:60px;height:60px;border-radius:50%;
    background:#e53935;color:white;font-size:26px;
    border:none;cursor:pointer;
}
</style>
</head>

<body>

<div class="overlay">
    <div class="header-dinas">
        <h1>DINAS PERTANIAN</h1>
        <p>KABUPATEN INDRAGIRI HILIR</p>
    </div>

    <div class="card">
        <h3>JADWAL PIKET JUMAT</h3>
        <div class="tanggal" id="tanggal"></div>
        <ul id="petugas"></ul>
    </div>
</div>

<button class="floating-download" onclick="downloadExcel()">⬇️</button>

<script>

// DATA PETUGAS (PUNYA KAMU)
const names = [
"Haryati Annisa","Yurindra Priska S","Nurhayaty","Rubiyah","Dewi Ratna Sari","Yolanda Sri Rahayu",
"Sukmayani","Novia Dwi A","Lisa Susanti","Gusti Ayu","Afrinola Mandrasari","Ema Hikmah",
"Siti Fatimah","Dwi Febri C","Tri Indah R","Yulia Anggraita","Dewi Wardati","Ratih Cristina Dewi","Tina Fitriyani",
"Khairiah","Misnah","Ayuni Apri Lanika","Sri Suryani","Annisa Angraini","Selvia","Yuliana",
"Rifa'atul Ridha","Liani","Maya Restia N","Fatimah","Nurpah","Siti Zubaidah",
"Nita Hayati","Thiara Septina D","Indah Chairunnisa","Yusa Alisa Putri","Riska Wulandari","Nova Yunita",
"Sarinah","Kurniati Ramayulis","Widuri Novelasari","Sri Wahyuni","Megawati","Saniah",
"Vera Gustina","Resti Tiaranti","Vanissa Aldi","Rodiana Wirasati","Rosmawati","Sartika Yuliani"
];

// cari Jumat minggu berjalan
function getNextFriday(){
    const today = new Date();
    const day = today.getDay();

    let diff = 5 - day;
    if(diff < 0) diff += 7;

    const friday = new Date(today);
    friday.setDate(today.getDate() + diff);

    return friday;
}

// generate jadwal full tahun
function generateSchedule(){
    let schedule=[];
    let index=0;

    const start=new Date("2026-01-01");
    const end=new Date("2026-12-31");

    for(let d=new Date(start); d<=end; d.setDate(d.getDate()+1)){
        if(d.getDay()===5){ // Jumat

            let team=[];
            for(let i=0;i<6;i++){
                team.push(names[index % names.length]);
                index++;
            }

            schedule.push({
                tanggal:d.toISOString().split("T")[0],
                petugas:team
            });
        }
    }

    return schedule;
}

const schedule = generateSchedule();
const targetFriday = getNextFriday();
const targetISO = targetFriday.toISOString().split("T")[0];

// tampilkan tanggal
document.getElementById("tanggal").textContent =
targetFriday.toLocaleDateString("id-ID",{weekday:"long",year:"numeric",month:"long",day:"numeric"});

// tampilkan petugas
const data = schedule.find(s=>s.tanggal===targetISO);
const list = document.getElementById("petugas");

if(data){
    data.petugas.forEach(n=>{
        const li=document.createElement("li");
        li.textContent=n;
        list.appendChild(li);
    });
}

// download excel (bulan berjalan)
function downloadExcel(){
    const now=new Date();

    const dataBulan = schedule.filter(s=>{
        const d=new Date(s.tanggal);
        return d.getMonth()===now.getMonth();
    });

    const excelData = dataBulan.map(s=>[
        s.tanggal, ...s.petugas
    ]);

    const ws=XLSX.utils.aoa_to_sheet([
        ["Tanggal","Petugas 1","Petugas 2","Petugas 3","Petugas 4","Petugas 5","Petugas 6"],
        ...excelData
    ]);

    const wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,ws,"Jadwal");
    XLSX.writeFile(wb,"Jadwal_Piket.xlsx");
}

</script>

</body>
</html>